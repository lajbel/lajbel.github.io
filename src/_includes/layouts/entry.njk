<!DOCTYPE html>

<html>
	<head>
		<title>LaJBlog - {{ title }}</title>
		<link rel="stylesheet" href="/styles/styles.css" />
		<link rel="stylesheet" href="/styles/entry.css" />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
		/>
		<link rel="icon" href="/favicon.ico" />

		{% include "partials/meta.njk" %}
	</head>

	<body>
		<header>{% include "partials/nav.njk" %}</header>

		<main class="blog entry">
			<div class="entry-card">
				<h1>{{ title }}</h1>
				<p>
					From <a href="{{ source[1] }}">{{ source[0] }}</a> -
					{{ tdate | join("/") }}
				</p>

				<img src="{{ bannerImage }}" />

				<p>{{ blog | safe }}</p>
			</div>
		</main>

		<footer>
			<p>{{ footer | safe }}</p>
		</footer>
	</body>
</html>
