<!DOCTYPE html>

<html>
	<head>
		<title>{{ title }}</title>
		<link rel="stylesheet" href="./styles/styles.css">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
		<link rel="icon" href="./favicon.ico">
	</head>

	<body>
		<header>
			{% include "partials/nav.njk "%}
		</header>

		<main>
			<h1 id="name"><i class="fa-solid fa-angle-left"></i> {{ name | safe }} <i class="fa-solid fa-angle-right"></i></h1>

			<div class="bio">
				<p>{{ bio | safe }}</p>
			</div>

			<ul class="social">
				{% for social in socials %}
					<li>{{ social | safe }}</li>
				{% endfor %}
			</ul>
		</main>

		<footer>
			<p>{{ footer | safe }}</p>
		</footer>
	</body>
</html>